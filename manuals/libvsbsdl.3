.nf
.Ft const char *
.Fo libvsbsdl_get_version
.Fa "void"
.Fc
.fi
.nf
.Ft int
.Fo libvsbsdl_get_access_flags_read
.Fa "void"
.Fc
.fi
.nf
.Ft int
.Fo libvsbsdl_get_access_flags_read_write
.Fa "void"
.Fc
.fi
.nf
.Ft int
.Fo libvsbsdl_get_access_flags_write
